# 本番（Docker / Hetzner）用。コピーして .env.production として使う:
#   copy .env.production.example .env.production   (Windows)
#   cp .env.production.example .env.production     (Linux/macOS)

# docker-compose.yml 側で DATABASE_URL を上書きするため、ここでは未設定でも可。
# 単体 docker run する場合は次のように指定:
# DATABASE_URL="file:/app/data/prod.db"

# 公開 URL（必ず https の本番ドメイン）
NEXTAUTH_URL="https://example.com"

# openssl rand -base64 32 などで生成した強いランダム文字列
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# Google Sheets（使う場合のみ）
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_SHEETS_RANGE="Sheet1!A1"
