# SQLite（開発用）
DATABASE_URL="file:./prisma/dev.db"

# 本番（Docker / Hetzner）では docker-compose の DATABASE_URL=file:/app/data/prod.db を使う例が多いです。
# 詳細は .env.production.example と deploy/HETZNER.md を参照。

# NextAuth（`openssl rand -base64 32` などで生成）
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-long-random-string"

# Google Sheets API（サービスアカウント利用時）
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_SHEETS_RANGE="Sheet1!A1"
